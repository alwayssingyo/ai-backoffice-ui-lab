{
  "name": "cms-config",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "npm run build:prod",
    "build:dev": "vite build --mode development && tsc",
    "build:prod": "vite build --mode production && tsc",
    "preview": "vite preview",
    "test": "playwright test --project=integration-chrome",
    "test:ui": "PLAYWRIGHT_SERIAL=true playwright test --ui",
    "test:ui:all": "PLAYWRIGHT_SERIAL=true playwright test --ui",
    "test:ui:chrome": "PLAYWRIGHT_SERIAL=true playwright test --ui --project=integration-chrome --project=e2e-chrome",
    "test:ui:firefox": "PLAYWRIGHT_SERIAL=true playwright test --ui --project=integration-firefox --project=e2e-firefox",
    "test:ui:safari": "PLAYWRIGHT_SERIAL=true playwright test --ui --project=integration-webkit --project=e2e-webkit",
    "test:integration": "playwright test --project=integration-chrome",
    "test:integration:firefox": "playwright test --project=integration-firefox",
    "test:integration:safari": "playwright test --project=integration-webkit",
    "test:integration:all": "playwright test --project=integration-chrome --project=integration-firefox --project=integration-webkit",
    "test:e2e": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-chrome",
    "test:e2e:firefox": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-firefox",
    "test:e2e:safari": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-webkit",
    "test:e2e:all": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-chrome --project=e2e-firefox --project=e2e-webkit",
    "test:smoke": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-chrome --grep @smoke",
    "test:smoke:all": "PLAYWRIGHT_SERIAL=true playwright test --project=e2e-chrome --project=e2e-firefox --project=e2e-webkit --grep @smoke",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "biome:format": "biome format --write --no-errors-on-unmatched",
    "biome:write": "biome lint --write --no-errors-on-unmatched",
    "biome:check:write": "biome check --write --no-errors-on-unmatched",
    "biome:check:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "i18n:init": "i18next-cli init",
    "i18n:status": "i18next-cli status",
    "i18n:extract": "i18next-cli extract",
    "i18n:extract:sync-primary": "i18next-cli extract --sync-primary",
    "i18n:extract:dev": "i18next-cli extract --sync-primary --watch",
    "i18n:types": "i18next-cli types",
    "i18n:types:watch": "i18next-cli types --watch",
    "i18n:lint": "i18next-cli lint",
    "i18n:lint:watch": "i18next-cli lint --watch",
    "i18n:sync": "i18next-cli sync",
    "husky:prepare": "cd .. && husky web/.husky",
    "kubb:generate": "kubb generate",
    "kubb:generate:dev": "kubb generate --mode development",
    "kubb:generate:prod": "kubb generate --mode production",
    "antd:generate": "tsx src/scripts/generate-antd-variables.ts",
    "img:generate": "tsx src/scripts/generate-image-constant.ts"
  },
  "dependencies": {
    "@ebay/nice-modal-react": "^1.2.13",
    "@react-oauth/google": "^0.13.4",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "antd": "^6.1.4",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.43.0",
    "griddy-icons": "^0.1.2",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.3",
    "jwt-decode": "^4.0.0",
    "randexp": "^0.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@faker-js/faker": "^10.2.0",
    "@kubb/cli": "^4.14.1",
    "@kubb/core": "^4.13.1",
    "@kubb/plugin-client": "^4.14.1",
    "@kubb/plugin-faker": "^4.14.1",
    "@kubb/plugin-oas": "^4.19.2",
    "@kubb/plugin-react-query": "^4.13.1",
    "@kubb/plugin-ts": "^4.13.1",
    "@playwright/test": "^1",
    "@tanstack/devtools-vite": "^0.3.11",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "i18next-cli": "^1.35.0",
    "lint-staged": "^15.4.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "web-vitals": "^5.1.0"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,css,scss,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
